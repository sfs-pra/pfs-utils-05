#!/bin/sh
#rebuild loaded or installed pfs
#VERSION 4.0
#260301 sfs
# Ensure pfs-utils binaries are resolvable via which(1) when invoked from a
# restricted PATH (e.g. systemd, GUI, sudo without --preserve-env).
PATH="/usr/bin:/usr/sbin:${PATH}"
export PATH
if ! command -v pfs >/dev/null 2>&1; then
    PATH="$(dirname "$0"):${PATH}"
    export PATH
fi
# shellcheck source=/dev/null
. "$(which pfs)"

pfsrebuild_resolve_fileslist() {
    identity="$1"
    case "${identity}" in
        *:*)
            mount_index_dir="$(pfsdir_mount_find "${identity}" 2>/dev/null || true)"
            if [ -n "${mount_index_dir}" ] && [ -f "${mount_index_dir}/pfs.files" ]; then
                printf '%s\n' "${mount_index_dir}/pfs.files"
                return 0
            fi
            return 1
            ;;
    esac

    install_dir="$(pfsdir_install_find "${identity}" 2>/dev/null || true)"
    if [ -n "${install_dir}" ] && [ -f "${install_dir}/pfs.files" ]; then
        printf '%s\n' "${install_dir}/pfs.files"
        return 0
    fi

    mount_index_dir="$(pfsdir_mount_find "${identity}" 2>/dev/null || true)"
    if [ -n "${mount_index_dir}" ] && [ -f "${mount_index_dir}/pfs.files" ]; then
        printf '%s\n' "${mount_index_dir}/pfs.files"
        return 0
    fi

    return 1
}

pfsrebuild_container_identities() {
    package_name="$1"
    # prefixmp is provided by sourced pfs runtime configuration.
    # shellcheck disable=SC2154
    container_root="${prefixmp}${package_name}.${EXT}"
    [ -d "${container_root}" ] || return 1

    old_new="${PFSDIR_MOUNT_NEW}"
    old_legacy="${PFSDIR_MOUNT_LEGACY}"
    PFSDIR_MOUNT_NEW="${container_root}${old_new}"
    PFSDIR_MOUNT_LEGACY="${container_root}${old_legacy}"

    pfsdir_mount_iter_indexes | while IFS="$(printf '\t')" read -r container submodule _path origin ; do
        [ -n "${submodule}" ] || continue
        case "${origin}" in
            new) printf '%s:%s\n' "${container}" "${submodule}" ;;
            legacy) printf '%s\n' "${submodule}" ;;
        esac
    done

    PFSDIR_MOUNT_NEW="${old_new}"
    PFSDIR_MOUNT_LEGACY="${old_legacy}"
}

if [ "${PFSREBUILD_SOURCE_ONLY:-0}" = "1" ]; then
    # shellcheck disable=SC2317
    return 0 2>/dev/null || exit 0
fi

#help
HLP(){
echo "Usage: $(basename "$0") <PACKAGE> <args for mkpfs>"
exit 1
}

case "$1" in
    "" | -h | --help)  HLP ;;
    "-"*[A-Za-z]*) echo "$(basename "$0"): invalid option -- $1" ; HLP ;;
esac

allow_only_root
pfs_aufs_only_runtime "$(basename "$0")" || exit $?
identity_name=$(basename "${1%."$EXT"}")
package_name=${identity_name#*:}
shift

fileslist="$(pfsrebuild_resolve_fileslist "${identity_name}" || true)"
[ -n "${fileslist}" ] && dirsempty="${fileslist%/pfs.files}/pfs.dirs.empty" || dirsempty=""

# find pfs files in pfs contaners
if [ -z "${fileslist}" ] || [ ! -f "${fileslist}" ] ; then
	package_list="$(pfsrebuild_container_identities "${package_name}" || true)"
	if [ -n "${package_list}" ] ; then
	echo "$package_list"
		pfs_in_contaner=''
		for pack in $package_list ; do
			printf 'pfsrebuild  %s --nopfs\n' "$pack"
			pfsrebuild  "$pack" --nopfs || exitmsg "can't rebuild package $pack" $?
			pack_name="${pack#*:}"
			pfs_in_contaner="$pfs_in_contaner ./${pack_name%."$EXT"}"
		done
		printf 'mkpfs %s -o %s' "$pfs_in_contaner" "${package_name}.${EXT}"
		for arg in "$@" ; do
			printf ' %s' "$arg"
		done
		printf '\n'
		# Module paths are generated by this script and pfs-utils rejects whitespace in module names.
		# shellcheck disable=SC2086
		set -- $pfs_in_contaner -o "${package_name}.${EXT}" "$@"
		mkpfs "$@"
		exitmsg "can't create contaner" $?
	else
		echo "Package \"$package_name\" is not installed!" >&2
		exit 1
	fi
exit
fi

if [ -f "${fileslist}" ] ; then
  buildir="./build_${package_name}/${package_name}"
  mkdir -p "$buildir"
  tar -c -p --ignore-failed-read --no-recursion -T "$fileslist"  2>/dev/null | tar -x -p -C "${buildir}"
  if [ -f  "${dirsempty}" ] ; then
	sed -e 's:^[^/]*::' -e 's:[\]:\\\\:g' "$dirsempty" | while read -r emptydir ; do
	#it is a hack to save owner and permissions for empty dirs
	cp -a --parents "$emptydir"/not_existing_filename "${buildir}/" 2>/dev/null
	done
  fi
  # --nopfs parameter - make build dir and exit 
  if echo "$@" | grep -qE "(^| )--?nopfs( |$)" ; then 
	rm -rf ./"${package_name}" && mv -f "${buildir}" ./
  else
	mkpfs "${buildir}" -o "${package_name}.${EXT}" "$@"
	exitmsg "can't create module" $?
  fi
  rm -rf ./build_"${package_name}"
  else
  echo "Package \"$package_name\" is not installed!" >&2
  exit 1
fi

exit 0
